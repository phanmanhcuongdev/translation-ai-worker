APP_NAME=AI-Translation-Worker
APP_VERSION=1.0.0
APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_USER=translation
POSTGRES_PASSWORD=translation_password
POSTGRES_DB=translation_cache
POSTGRES_DSN=postgresql://translation:translation_password@postgres:5432/translation_cache
POSTGRES_MIN_SIZE=1
POSTGRES_MAX_SIZE=5

RABBITMQ_DEFAULT_USER=translation
RABBITMQ_DEFAULT_PASS=translation_password
RABBITMQ_URL=amqp://translation:translation_password@rabbitmq:5672/
RABBITMQ_EXCHANGE=feedback.exchange
RABBITMQ_QUEUE=feedback.translate.queue
RABBITMQ_ROUTING_KEY=feedback.translate.key
RABBITMQ_REPLY_EXCHANGE=translation.reply.exchange
RABBITMQ_REPLY_QUEUE=translation.reply.queue
RABBITMQ_REPLY_ROUTING_KEY=translation.reply.key
RABBITMQ_REPLY_DLX=translation.reply.dlx
RABBITMQ_REPLY_DLQ=translation.reply.dlq
RABBITMQ_DLQ=translation.dead-letter.queue
RABBITMQ_RECONNECT_SECONDS=5
RABBITMQ_MAX_RETRIES=3

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2:7b
TRANSLATION_TARGET_LANG=vi
OLLAMA_REQUEST_TIMEOUT_SECONDS=180
OLLAMA_NUM_CTX=2048
MAX_CONTENT_CHARS=8000
GPU_ADVISORY_LOCK_KEY=1050
